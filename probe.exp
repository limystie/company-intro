#!/usr/bin/expect -f

set timeout 10
set ip "43.173.100.169"
set user "ubuntu"
set password "wahaha@18"

spawn ssh -o StrictHostKeyChecking=no $user@$ip "ls -la / && echo '---' && ls -la /var/www || echo '/var/www not found' && echo '---' && ls -la /www/wwwroot || echo '/www/wwwroot not found'"

expect {
    "password:" {
        send "$password\r"
        exp_continue
    }
    timeout {
        puts "Connection timed out"
        exit 1
    }
    eof
}
